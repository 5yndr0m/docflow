# ─── Ollama ───────────────────────────────────────────────────────────────────
# URL to the Ollama service. In Docker Compose, this uses the service name.
OLLAMA_BASE_URL=http://ollama:11434

# Chat/reasoning model. Must be available in Ollama.
# Smaller = faster: llama3.2 (3B), mistral:7b
# Better quality: llama3.1:8b, qwen2.5:7b
OLLAMA_CHAT_MODEL=llama3.2

# Embedding model. Must support /api/embed endpoint.
# nomic-embed-text is fast, small, and high quality (768 dims).
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_COLLECTION_NAME=lumen_docs

# ─── Database ─────────────────────────────────────────────────────────────────
# Four slashes = absolute path in SQLite URL
SQLITE_URL=sqlite+aiosqlite:////data/lumen.db

# ─── Storage ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads

# ─── RAG Parameters ───────────────────────────────────────────────────────────
# Characters per chunk (not tokens). 512–1024 is a good range.
CHUNK_SIZE=512

# Character overlap between consecutive chunks. Prevents context loss at edges.
CHUNK_OVERLAP=64

# Number of nearest neighbor chunks to retrieve per query.
TOP_K=5

# Max chunks sent to LLM after deduplication. Keeps context window manageable.
MAX_CONTEXT_CHUNKS=8

# ─── App Server ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080

# Secret used to sign NiceGUI browser session cookies. Change in production.
NICEGUI_STORAGE_SECRET=change-me-in-production-use-a-random-string

# ─── Development ──────────────────────────────────────────────────────────────
# Set to true to enable SQLAlchemy query logging and FastAPI debug mode.
DEBUG=false
